<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_main"
        app:title="@string/title_qr_tickets"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- White Form Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/formContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- From Station -->
        <EditText
            android:id="@+id/etFromStation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="24dp"
            android:hint="@string/hint_from_station"
            android:textColorHint="#757575"
            android:textColor="@color/text_primary"
            android:backgroundTint="#BDBDBD"
            android:paddingVertical="12dp"
            android:textSize="18sp"
            android:focusable="false"
            android:clickable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSwap" />

        <!-- To Station -->
        <EditText
            android:id="@+id/etToStation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_to_station"
            android:textColorHint="#757575"
            android:textColor="@color/text_primary"
            android:backgroundTint="#BDBDBD"
            android:paddingVertical="12dp"
            android:textSize="18sp"
            android:focusable="false"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/etFromStation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSwap" />

        <!-- Swap Button -->
        <ImageView
            android:id="@+id/btnSwap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_swap_icon"
            android:src="@drawable/ic_swap_vert"
            android:padding="12dp"
            android:contentDescription="@string/desc_swap"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/etFromStation"
            app:layout_constraintBottom_toBottomOf="@id/etToStation" />

        <!-- Passengers Label -->
        <TextView
            android:id="@+id/tvPassengersLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="@string/label_passengers"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/etToStation"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Passenger Counter -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_passenger_counter"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvPassengersLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvPassengersLabel">

            <ImageView
                android:id="@+id/btnRemovePassenger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_remove"
                android:contentDescription="@string/desc_remove" />

            <TextView
                android:id="@+id/tvPassengerCount"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/purple_main"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <ImageView
                android:id="@+id/btnAddPassenger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_add"
                android:contentDescription="@string/desc_add" />
        </LinearLayout>

        <!-- Purchase Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPurchaseConfirm"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="64dp"
            android:layout_marginTop="48dp"
            android:text="PURCHASE"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/purple_main"
            app:layout_constraintTop_toBottomOf="@id/tvPassengersLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
